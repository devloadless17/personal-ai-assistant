// Multi-tenant Telegram AI executive assistant — data model.
//
// Tenancy rule: every client-owned model carries `clientId` and every query in
// application code goes through the tenancy layer, which injects the clientId
// filter. Composite indexes below match every hot access path so query plans
// stay index-range scans regardless of table size (see plan: bounded,
// windowed data access — no query ever fetches "all").

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ClientStatus {
  active
  disabled
}

enum TaskType {
  task
  reminder
}

enum TaskStatus {
  open
  done
}

enum RecurrenceFreq {
  DAILY
  WEEKLY
  MONTHLY
}

enum MessageDirection {
  inbound
  outbound
}

model Client {
  id        String       @id @default(cuid())
  name      String
  status    ClientStatus @default(active)
  timezone  String // IANA, e.g. "Asia/Riyadh"

  /// The client's Gmail — set by the admin. Enables the client to log into
  /// their self-service portal via "Sign in with Google". Unique so one
  /// Google account maps to exactly one client.
  email String? @unique

  /// Assistant persona name filled into {{ASSISTANT_NAME}}
  assistantName String @default("Assistant")

  // ── Telegram (one dedicated bot per client) ──────────────────────────────
  /// Bot token, AES-256-GCM encrypted at rest (format: iv:ciphertext:tag, hex)
  telegramBotTokenEnc String?
  /// The bot's @username (public) — used to build the t.me link the admin
  /// sends to the client. Not a secret.
  telegramBotUsername String?
  /// One-time bind code embedded in the t.me deep link (?start=<code>). Only a
  /// first chat that presents this exact code may bind — so a leaked/guessed
  /// bot link alone can't hijack the client's assistant. Regenerated on every
  /// (re)connect and on reset-binding.
  telegramBindCode    String?
  /// Chat id of the client's private chat with their bot
  telegramChatId      String?
  /// Secret token we set on the webhook; Telegram echoes it back on every
  /// update and we reject anything that doesn't match. Encrypted at rest.
  telegramWebhookSecretEnc String?

  // ── Google Calendar (per-client OAuth) ───────────────────────────────────
  /// OAuth token bundle (refresh/access/expiry) as encrypted JSON
  googleOAuthEnc String?
  /// Set when a refresh fails permanently — client must re-authorize
  googleNeedsReauth Boolean @default(false)

  // ── Reminder preferences ───────────────────────────────────────────────────
  /// Default lead time (minutes before a task's due time) to send a reminder.
  /// The client can change this ("always remind me 30 minutes before") and can
  /// override it per task in chat. 0 = don't add reminders automatically.
  defaultReminderMinutes Int @default(15)

  // ── Daily brief ──────────────────────────────────────────────────────────
  /// Local hour (0-23) to send the morning brief
  dailyBriefHour Int @default(7)
  /// Last local date ("YYYY-MM-DD" in the client's tz) a brief was sent —
  /// idempotency marker so restarts/re-runs can never double-send
  lastBriefDate String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks          Task[]
  memories       Memory[]
  messages       Message[]
  auditLogs      AuditLog[]
  conflictAlerts CalendarConflictAlert[]

  @@index([status])
  // Admin client list: ORDER BY createdAt DESC
  @@index([createdAt])
}

model Task {
  id       String     @id @default(cuid())
  clientId String
  client   Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)

  title  String
  type   TaskType   @default(task)
  status TaskStatus @default(open)

  /// Due date-time in UTC (interpreted/displayed in the client's timezone)
  dueAt DateTime?

  /// When to push a reminder to the client's Telegram (UTC)
  reminderAt   DateTime?
  reminderSent Boolean   @default(false)
  /// Lease timestamp for at-least-once delivery: set when a tick claims this
  /// reminder to send it, cleared/confirmed after. If a process dies between
  /// claiming and sending, a later tick re-claims the stale lease so the
  /// reminder is never silently lost (a rare duplicate beats a missed ping).
  reminderClaimedAt DateTime?

  /// If set, this task is a companion REMINDER for a Google Calendar event
  /// (not a user-facing task). Lets us move/cancel it with the event and hide
  /// it from task lists. Stores the Google event id.
  sourceEventId String?
  /// Lead time (minutes) for a calendar companion reminder, so a moved event
  /// keeps the same lead.
  reminderLeadMinutes Int?

  /// Recurrence (null freq = one-shot). When set, the reminder cron re-arms the
  /// SAME row to the next occurrence after each send instead of marking it done.
  recurrenceFreq     RecurrenceFreq?
  recurrenceInterval Int?            @default(1)
  /// For WEEKLY: which weekdays (0=Sun … 6=Sat), e.g. [5] = every Friday.
  recurrenceWeekdays Int[]           @default([])
  /// Optional end of the series (inclusive-ish); past this, it stops.
  recurrenceUntil    DateTime?
  /// The series' ORIGINAL first occurrence — the immutable anchor. Monthly
  /// recurrence computes each occurrence's day-of-month from this so a "31st"
  /// reminder recovers to the 31st after a short month, never drifting to the 28th.
  recurrenceAnchor   DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Windowed reads: "open tasks from today forward", "overdue", "done last month"
  @@index([clientId, status, dueAt])
  // Reminder cron: WHERE reminderSent = false AND reminderAt <= now()
  @@index([reminderSent, reminderAt])
  @@index([clientId, createdAt])
  // Companion-reminder lookup on event move/delete
  @@index([clientId, sourceEventId])
  // Admin diagnostics "recent reminders" panel: global ORDER BY reminderAt DESC
  @@index([reminderAt])
}

model Memory {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  key      String
  value    String
  category MemoryCategory @default(LONGTERM)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One value per key per client; upserts are the write path
  @@unique([clientId, key])
  // Profile load orders by updatedAt desc — keep the sort index-satisfied
  @@index([clientId, updatedAt])
}

enum MemoryCategory {
  PROFILE
  PREFERENCE
  LONGTERM
}

/// De-dup record for proactive "you have a double-booking" Telegram alerts, so
/// the background calendar sweep alerts once per distinct conflict, not every
/// tick. conflictKey is a stable hash of the two event ids + their start times.
model CalendarConflictAlert {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  conflictKey String
  alertedAt   DateTime @default(now())

  @@unique([clientId, conflictKey])
  @@index([clientId, alertedAt])
  // Supports the global TTL cleanup (deleteMany where alertedAt < cutoff)
  @@index([alertedAt])
}

model Message {
  id       String           @id @default(cuid())
  clientId String
  client   Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)

  direction MessageDirection
  content   String

  /// Telegram update_id — dedup key: Telegram redelivers webhooks on timeout,
  /// and the unique constraint makes double-processing impossible.
  telegramUpdateId BigInt?

  createdAt DateTime @default(now())

  // Context assembly: last N by (clientId, createdAt DESC) LIMIT N;
  // id as tiebreaker so same-millisecond bursts paginate correctly
  @@index([clientId, createdAt, id])
  @@unique([clientId, telegramUpdateId])
}

model AuditLog {
  id       String @id @default(cuid())
  clientId String
  /// Restrict, NOT Cascade: the audit trail is the system's evidence record —
  /// deleting a client must never silently destroy it. Clients are disabled
  /// (status) rather than deleted; a hard delete requires explicit,
  /// deliberate handling of the audit history first.
  client   Client @relation(fields: [clientId], references: [id], onDelete: Restrict)

  toolName String
  input    Json
  result   Json
  success  Boolean

  createdAt DateTime @default(now())

  // Dashboard: cursor-paginated per-client log, filterable by tool/success;
  // id as tiebreaker so same-millisecond bursts paginate correctly
  @@index([clientId, createdAt, id])
  @@index([clientId, toolName, createdAt])
}

model AdminUser {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
