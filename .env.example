# ──────────────────────────────────────────────────────────────────────────────
# Environment configuration — copy to `.env` and fill in. NEVER commit `.env`.
# The API validates every variable at boot and refuses to start if one is
# missing or malformed (see apps/api/src/config/env.validation.ts).
# ──────────────────────────────────────────────────────────────────────────────

# ── Deployment (docker compose / Caddy) ──────────────────────────────────────
# Public domain served by the reverse proxy, e.g. assistant.example.com
# Caddy provisions TLS automatically once DNS points here.
DOMAIN=localhost

# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
# Port the NestJS API listens on
API_PORT=3001
# Public base URL of the API (used for Telegram webhooks + Google OAuth redirect)
# e.g. https://assistant.example.com/api
PUBLIC_API_URL=http://localhost:3001
# Public base URL of the admin dashboard
PUBLIC_WEB_URL=http://localhost:3000

# ── Database (your existing VPS Postgres) ────────────────────────────────────
# postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public
DATABASE_URL=

# ── Secrets encryption ───────────────────────────────────────────────────────
# 32-byte hex key for AES-256-GCM encryption of per-client secrets at rest.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ── Admin auth ───────────────────────────────────────────────────────────────
# Secret for signing admin JWTs. Generate with: openssl rand -hex 32
JWT_SECRET=

# ── Anthropic (Milestone 2) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ── Google OAuth (Milestone 4) ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must be registered in your Google Cloud OAuth client:
# ${PUBLIC_API_URL}/google/oauth/callback
GOOGLE_REDIRECT_URI=

# ── Dashboard admin (bootstrapped at first boot if no admin exists) ──────────
ADMIN_EMAIL=
# At least 12 characters
ADMIN_PASSWORD=

# ── Admin alerting (Milestone 5) ─────────────────────────────────────────────
# Bot token + your chat id for critical-failure alerts to YOUR Telegram
ADMIN_ALERT_BOT_TOKEN=
ADMIN_ALERT_CHAT_ID=
