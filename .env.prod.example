# ──────────────────────────────────────────────────────────────────────────────
# PRODUCTION .env TEMPLATE — rendered by CI on every deploy.
#
# The GitHub Actions deploy job copies this file to `.env.rendered`, substitutes
# every __PLACEHOLDER__ with the matching GitHub secret, and ships it to the VPS
# as `.env`. Do NOT put real values here — this file is committed. Real values
# live in the repo's GitHub Actions secrets (Settings → Secrets → Actions).
#
# The API validates every variable at boot (apps/api/src/config/env.validation.ts)
# and refuses to start on bad config, so a mis-rendered value fails the deploy's
# health gate instead of silently shipping.
# ──────────────────────────────────────────────────────────────────────────────

# ── Image coordinates (set by CI) ────────────────────────────────────────────
# DOCKER_USERNAME + IMAGE_TAG are interpolated into docker-compose.prod.yml.
# IMAGE_TAG is rewritten by CI from `latest` to the deployed commit SHA so the
# stack pins to an immutable image (reliable recreate + SHA-based rollback).
DOCKER_USERNAME=__DOCKER_USERNAME__
IMAGE_TAG=latest

# ── Deployment / Caddy ───────────────────────────────────────────────────────
DOMAIN=__DOMAIN__

# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
API_PORT=3001
PUBLIC_API_URL=https://__DOMAIN__/api
PUBLIC_WEB_URL=https://__DOMAIN__

# ── Database (Postgres container in this stack) ──────────────────────────────
# The `postgres` service in docker-compose.prod.yml is initialized from these
# on FIRST boot only; the data then lives in the `pgdata` volume and survives
# redeploys. Postgres is NOT published to the host — only the api reaches it over
# the private Docker network — so a fixed password is fine and needs no secret.
# To change it later: edit both values below, then ALTER ROLE on the existing DB
# (the volume keeps the old password until you do).
POSTGRES_USER=assistant
POSTGRES_DB=assistant
POSTGRES_PASSWORD=assistant
# The api reaches the DB by the compose service name `postgres`.
DATABASE_URL=postgresql://assistant:assistant@postgres:5432/assistant?schema=public

# ── Secrets encryption (openssl rand -hex 32) ────────────────────────────────
ENCRYPTION_KEY=__ENCRYPTION_KEY__

# ── Admin auth (openssl rand -hex 32) ────────────────────────────────────────
JWT_SECRET=__JWT_SECRET__

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=__ANTHROPIC_API_KEY__
ANTHROPIC_MODEL=claude-opus-4-8

# ── Voice transcription (OpenAI Whisper) ─────────────────────────────────────
# Lets clients send voice notes instead of typing. Leave blank to disable voice.
OPENAI_API_KEY=__OPENAI_API_KEY__
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# ── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=__GOOGLE_CLIENT_ID__
GOOGLE_CLIENT_SECRET=__GOOGLE_CLIENT_SECRET__
GOOGLE_REDIRECT_URI=https://__DOMAIN__/api/google/oauth/callback

# ── Dashboard admin (bootstrapped at first boot if no admin exists) ──────────
ADMIN_EMAIL=__ADMIN_EMAIL__
ADMIN_PASSWORD=__ADMIN_PASSWORD__

# ── Admin alerting (optional — empty disables the feature) ────────────────────
ADMIN_ALERT_BOT_TOKEN=__ADMIN_ALERT_BOT_TOKEN__
ADMIN_ALERT_CHAT_ID=__ADMIN_ALERT_CHAT_ID__
